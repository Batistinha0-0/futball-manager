# Copy to `backend/.env` (gitignored). Used by uvicorn (pydantic-settings) and docker compose.

# --- FastAPI / uvicorn (local) ---
# Em produção (ex.: Render com SPA em OUTRO subdomínio), inclua a URL exata do front (scheme + host, sem path).
# Ex.: CORS_ORIGINS=https://futball-manager-1.onrender.com,http://localhost:5173
# Sem isso, o preflight OPTIONS do login costuma retornar 400 e o navegador bloqueia a chamada.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — used by start.py (defaults: 127.0.0.1, 8000, reload on)
# API_HOST=127.0.0.1
# API_PORT=8000
# API_RELOAD=1

# Postgres on host → Docker DB: use 127.0.0.1 (not "db") when API runs outside Compose.
# Uncomment for local dev with `docker compose up -d`:
# DATABASE_URL=postgresql+psycopg://futball:futball@127.0.0.1:5432/futball
# Neon / Render: postgresql+psycopg://… Leave empty for in-memory DB (tests / quick dev).
DATABASE_URL=

# Auth (required when DATABASE_URL is set — login / JWT cookies)
# JWT_SECRET=change-me-in-production
# JWT_ACCESS_EXPIRES_MINUTES=15
# JWT_REFRESH_EXPIRES_DAYS=7
# AUTH_COOKIE_NAME=fm_access
# AUTH_REFRESH_COOKIE_NAME=fm_refresh
# Optional pepper for refresh token hashing; if unset, JWT_SECRET is used (document for dev only).
# REFRESH_TOKEN_PEPPER=
# SPA e API em hosts diferentes (*.onrender.com são cross-site): use SameSite=none + Secure em HTTPS.
# AUTH_COOKIE_SECURE=1
# AUTH_COOKIE_SAMESITE=none
# Local HTTP:
# AUTH_COOKIE_SECURE=0
# AUTH_COOKIE_SAMESITE=lax

# Optional first account (role `super_admin`, same permissions as admin). Runs once after migrations
# if this user_name does not exist yet. Omit both to skip. Use only in controlled environments.
# BOOTSTRAP_SUPER_ADMIN_USER_NAME=superadmin
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=change-me-immediately

# --- docker compose (Postgres container only) ---
POSTGRES_USER=futball
POSTGRES_PASSWORD=futball
POSTGRES_DB=futball
POSTGRES_PORT=5432
