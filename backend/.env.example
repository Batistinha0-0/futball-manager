# Copy to `backend/.env` (gitignored). Used by uvicorn (pydantic-settings) and docker compose.

# --- FastAPI / uvicorn ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (Neon, or local). Use postgresql+psycopg://… for SQLAlchemy + psycopg3.
# Leave empty for in-memory DB (tests / quick dev without Postgres).
DATABASE_URL=

# --- docker compose (optional overrides; defaults in docker-compose.yml) ---
POSTGRES_USER=futball
POSTGRES_PASSWORD=futball
POSTGRES_DB=futball
POSTGRES_PORT=5432
API_PORT=8000

# For `uvicorn` on the host with Postgres from compose: DATABASE_URL=...@127.0.0.1:5432/...

# Docker build: 1 if pip fails SSL to PyPI (corporate proxy). Use 0 on clean networks (e.g. Render).
PIP_TRUSTED_HOSTS=0
