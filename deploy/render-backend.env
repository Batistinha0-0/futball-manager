# =============================================================================
# Render — Web Service Python 3 (recomendado) — site + API na mesma URL
#
# Language: Python 3
# Root Directory: (vazio = raiz do repo)
#
# Build Command:
#   chmod +x deploy/render-build.sh && ./deploy/render-build.sh
#
# Start Command:
#   cd backend && python start.py
#
# Health Check Path: /health   (não uses /healthz — a API não tem esse path)
#
# Front: `vite.config` com base `/` — após build, CSS/JS em /assets/... (Safari em rotas como /login).
#
# CORS_ORIGINS: URL exata do browser deste serviço, ex. https://fut-manager.onrender.com
#
# Alternativa Docker: Dockerfile na raiz (sem Build/Start command no painel).
# =============================================================================

CORS_ORIGINS=https://fut-manager.onrender.com

DATABASE_URL=COLE_AQUI_A_DATABASE_URL_DO_NEON

APP_TIMEZONE=America/Sao_Paulo

JWT_SECRET=GERE_UMA_STRING_LONGA_E_ALEATORIA_EX_OPENSSL_RAND_BASE64_48
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=1440
JWT_REFRESH_EXPIRES_DAYS=7

AUTH_COOKIE_NAME=fm_access
AUTH_REFRESH_COOKIE_NAME=fm_refresh
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none

# Opcional: pepper extra para hash do refresh (se vazio, usa JWT_SECRET)
# REFRESH_TOKEN_PEPPER=

BOOTSTRAP_SUPER_ADMIN_USER_NAME=Fellipe
BOOTSTRAP_SUPER_ADMIN_PASSWORD=DEFINA_UMA_SENHA_FORTE_AQUI
