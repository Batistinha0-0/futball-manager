# =============================================================================
# Render — Web Service ÚNICO (recomendado: site + API na mesma URL = cookies no mobile)
#
# --- Se o Render estiver em "Docker" (recomendado com o Dockerfile na raiz do repo) ---
# Não precisas de Build Command nem Start Command à mão: o CMD do Dockerfile usa $PORT.
#
# --- Se usares runtime "Native" (Python) em vez de Docker ---
# Build:   chmod +x deploy/render-build.sh && ./deploy/render-build.sh
# Start:   cd backend && python start.py
#
# URL pública (ex.): https://futball-manager.onrender.com
# =============================================================================

# Mesma origem do SPA servido pelo FastAPI (ajusta ao teu domínio Render).
CORS_ORIGINS=https://futball-manager.onrender.com

# Neon / Postgres (cole a URL completa do painel; postgresql:// ou postgresql+psycopg://)
DATABASE_URL=COLE_AQUI_A_DATABASE_URL_DO_NEON

APP_TIMEZONE=America/Sao_Paulo

JWT_SECRET=GERE_UMA_STRING_LONGA_E_ALEATORIA_EX_OPENSSL_RAND_BASE64_48
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=1440
JWT_REFRESH_EXPIRES_DAYS=7

AUTH_COOKIE_NAME=fm_access
AUTH_REFRESH_COOKIE_NAME=fm_refresh
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none

# Opcional: pepper extra para hash do refresh (se vazio, usa JWT_SECRET)
# REFRESH_TOKEN_PEPPER=

# Opcional: cria super_admin na primeira subida se o user_name ainda não existir
BOOTSTRAP_SUPER_ADMIN_USER_NAME=Fellipe
BOOTSTRAP_SUPER_ADMIN_PASSWORD=DEFINA_UMA_SENHA_FORTE_AQUI
