# API base (no trailing slash). Leave empty in dev to use Vite proxy (/api → backend):
# cookies httpOnly ficam no mesmo site que o SPA (recomendado para login/refresh).
# VITE_API_URL=
#
# Se definir URL absoluta (ex.: http://127.0.0.1:8000), o browser trata como outro origin;
# em HTTPS pode precisar SameSite=None no backend para os cookies.
VITE_API_URL=
